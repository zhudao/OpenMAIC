tl.set('#fx-0-2',{autoAlpha:0},5);
tl.set('#fx-0-2-ring',{opacity:0},5);
tl.set('#subtitle-cue-0',{display:'inline-block'},0);
tl.set('#subtitle-cue-0',{display:'none'},2);
tl.set({}, {}, 7);
window.__timelines = window.__timelines || {};
